# Local development image. The binary is pre-built outside Docker using go.work
# (which resolves controller from the local sibling directory). The CI/production image
# is Dockerfile.agent, which builds entirely inside Docker using the published controller module.
FROM gcr.io/distroless/static:nonroot
COPY kubeswarm-runtime /kubeswarm-runtime
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/kubeswarm-runtime"]
